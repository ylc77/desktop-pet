{
  "schemaVersion": 1,
  "id": "_placeholder",
  "name": "开发占位角色",
  "version": "0.1.0",
  "author": "七酱桌宠",
  "license": "Project placeholder only",
  "defaultScale": 0.82,
  "frameSize": { "width": 256, "height": 256 },
  "anchor": { "x": 0.5, "y": 0.92 },
  "hitbox": { "x": 0.16, "y": 0.28, "width": 0.68, "height": 0.62 },
  "visual": {
    "dropShadow": false,
    "groundShadow": { "enabled": true, "width": 0.42, "height": 0.07, "opacity": 0.16, "blur": 5 }
  },
  "preview": "preview.png",
  "icon": "icon.png",
  "animations": {
    "idle": { "path": "animations/idle", "fps": 4, "loop": true, "priority": 10, "weight": 0, "minDelayMs": 3500, "maxDelayMs": 7500 },
    "blink": { "path": "animations/blink", "fps": 8, "loop": false, "returnTo": "idle", "priority": 20, "weight": 35, "minDelayMs": 3500, "maxDelayMs": 8000 },
    "walk": { "path": "animations/walk", "fps": 8, "loop": false, "returnTo": "idle", "priority": 30, "weight": 0, "minDelayMs": 9000, "maxDelayMs": 18000, "flipXAllowed": true, "movement": { "speed": 52, "acceleration": 140, "deceleration": 190, "edgePadding": 24 } },
    "sleep": { "path": "animations/sleep", "fps": 3, "loop": false, "returnTo": "idle", "priority": 40, "weight": 5, "minDelayMs": 30000, "maxDelayMs": 60000 },
    "click": { "path": "animations/click", "fps": 10, "loop": false, "returnTo": "idle", "interruptible": false, "priority": 80 },
    "drag": { "path": "animations/drag", "fps": 1, "loop": true, "priority": 100 },
    "land": { "path": "animations/land", "fps": 10, "loop": false, "returnTo": "idle", "priority": 90 },
    "happy": { "path": "animations/happy", "fps": 9, "loop": false, "returnTo": "idle", "priority": 70, "weight": 10, "minDelayMs": 12000, "maxDelayMs": 26000 }
  },
  "interactions": { "click": "click", "doubleClick": "happy", "hover": "blink", "drag": "drag", "land": "land", "cooldownMs": 350 },
  "skins": { "default": { "name": "默认占位" } }
}
