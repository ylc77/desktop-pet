{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "appearance",
  "description": "Minimal permissions for the offline appearance center window",
  "windows": ["appearance"],
  "permissions": [
    "core:event:allow-listen",
    "core:event:allow-unlisten",
    "allow-list-installed-characters",
    "allow-import-character-package",
    "allow-remove-installed-character",
    "allow-get-selected-character-id",
    "allow-request-character-selection"
  ]
}
