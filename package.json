{
  "name": "desk-pet-framework",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "build": "npm run validate:characters && tsc -b && vite build",
    "build:release": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-release.ps1",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run",
    "validate": "npm run typecheck && npm run test && npm run validate:characters && npm run build",
    "validate:characters": "node scripts/validate-character-pack.mjs",
    "package:character": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/package-character.ps1",
    "generate:placeholder": "node scripts/generate-placeholder.mjs",
    "check:windows-env": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/check-windows-env.ps1",
    "release:manifest": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/create-release-manifest.ps1",
    "qa:safe": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/windows/run-qa-suite.ps1 -Mode Safe",
    "qa:public-beta:audit": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/windows/audit-public-beta-readiness.ps1"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-autostart": "^2.5.1",
    "@tauri-apps/plugin-log": "^2.9.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.4",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.2",
    "jsdom": "^26.1.0",
    "pngjs": "^7.0.0",
    "sharp": "^0.34.3",
    "typescript": "~5.9.2",
    "vite": "^7.1.3",
    "vitest": "^3.2.4"
  }
}
