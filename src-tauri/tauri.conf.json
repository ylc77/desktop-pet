{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "七酱桌宠",
  "mainBinaryName": "desktop_pet",
  "version": "0.2.0",
  "identifier": "dev.deskpet.framework",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "七酱桌宠",
        "width": 420,
        "height": 420,
        "minWidth": 220,
        "minHeight": 220,
        "resizable": true,
        "fullscreen": false,
        "transparent": true,
        "decorations": false,
        "shadow": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; img-src 'self' asset: http://asset.localhost data:; style-src 'self' 'unsafe-inline'; object-src 'none'; frame-src 'none'; base-uri 'none'",
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["$APPLOCALDATA/characters/**/*.png"],
          "deny": ["$APPLOCALDATA/EBWebView/**/*"]
        }
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "",
      "endpoints": [],
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": false,
    "resources": {
      "../LICENSE": "LICENSE",
      "../THIRD_PARTY_LICENSES.txt": "THIRD_PARTY_LICENSES.txt",
      "../THIRD_PARTY_NOTICES.md": "THIRD_PARTY_NOTICES.md",
      "../docs/ASSET_RIGHTS.md": "docs/ASSET_RIGHTS.md"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "nsis": {
        "installMode": "currentUser",
        "languages": ["SimpChinese"],
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico"
      }
    }
  }
}
