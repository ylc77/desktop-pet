{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Permissions for the local desktop pet window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:default",
    "core:window:allow-hide",
    "core:window:allow-set-always-on-top",
    "core:window:allow-set-position",
    "core:window:allow-start-dragging",
    "autostart:default",
    "log:default",
    "allow-set-fullscreen-auto-hide",
    "allow-quit-app",
    "allow-read-settings-file",
    "allow-write-settings-file",
    "allow-quarantine-invalid-settings-file",
    "allow-list-installed-characters",
    "allow-load-installed-character",
    "allow-set-active-character-id",
    "allow-begin-character-activation",
    "allow-commit-character-selection",
    "allow-finalize-character-selection",
    "allow-cancel-character-selection",
    "allow-show-appearance-window"
  ]
}
